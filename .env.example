SLG_SHARED_SECRET=replace-with-at-least-32-random-characters
SLG_AUDIT_KEY=replace-with-different-at-least-32-random-characters
SLG_WORKSPACE=./workspace
SLG_POLICY_FILE=./policy.yaml
SLG_AUDIT_LOG=./audit.jsonl
# Optional: uncomment both only for separately protected anchor storage.
# SLG_AUDIT_ANCHOR_LOG=/path/to/separately-protected/audit-anchor.jsonl
# SLG_AUDIT_ANCHOR_KEY=replace-with-third-independent-at-least-32-random-characters
SLG_REPLAY_DB=./.systeme-local/replay.sqlite3
SLG_REPLAY_MAX_ENTRIES=10000
SLG_APPROVAL_DB=./.systeme-local/approvals.sqlite3
SLG_APPROVAL_MAX_ENTRIES=1000
SLG_APPROVAL_TTL_SECONDS=900
SLG_SANDBOX_ROOT=./.systeme-local/sandboxes
SLG_DOCKER_IMAGE=systeme-local-sandbox:dev
