FROM python:3.14-slim@sha256:d3400aa122fa42cf0af0dbe8ec3091b047eac5c8f7e3539f7135e86d855dc015

ARG PYTEST_VERSION=8.4.2

LABEL org.opencontainers.image.title="Système Local sandbox" \
      org.opencontainers.image.description="Restricted execution image for Système Local" \
      org.opencontainers.image.licenses="Apache-2.0"

ENV HOME=/tmp \
    PIP_NO_CACHE_DIR=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

RUN apt-get update \
    && apt-get install -y --no-install-recommends git \
    && python -m pip install "pytest==${PYTEST_VERSION}" \
    && rm -rf /var/lib/apt/lists/*

RUN groupadd --gid 10001 runner \
    && useradd --create-home --uid 10001 --gid 10001 --shell /usr/sbin/nologin runner

USER 10001:10001
WORKDIR /workspace
ENTRYPOINT []
